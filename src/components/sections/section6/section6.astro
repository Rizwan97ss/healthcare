---
import "./section6.css";
import mind6 from "../../../assets/images/mind6.svg";
---

<section class="section6">
    <div class="section6-left">
        <div class="logo">
            <img src={mind6.src} alt="" />
        </div>

        <h2 class="hd2">Easy Steps To Begin Your Wellness Journey</h2>

        <p class="body-md">
            Starting your wellness journey doesn't have to be overwhelming. By
            taking small, intentional steps, you can begin to cultivate a
            healthier mind and body, and create lasting positive habits.
        </p>

        <div class="btn6">
            <button class="button-lg">Button</button>
        </div>
    </div>

    <div class="section6-right">
        <div class="step">
            <span class="step-num hd4">01</span>
            <div>
                <h3 class="hd3">Reach Out for Support</h3>
                <p class="body-md">
                    Contact us to schedule an appointment with one of our
                    experienced mental health professionals.
                </p>
            </div>
        </div>

        <div class="step">
            <span class="step-num hd4">02</span>
            <div>
                <h3 class="hd3">Personalized Care Plan</h3>
                <p class="body-md">
                    We will create a personalized mental health plan, including
                    therapy sessions, resources, and coping strategies.
                </p>
            </div>
        </div>

        <div class="step">
            <span class="step-num hd4">03</span>
            <div>
                <h3 class="hd3">Ongoing Support & Growth</h3>
                <p class="body-md">
                    Our team will support you through every stage of your
                    progress.
                </p>
            </div>
        </div>
    </div>
</section>