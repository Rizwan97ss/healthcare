---
import "./Hero.css";

import heroImage from "../../../assets/images/Hero.jpg";
import plusIcon from "../../../assets/images/plus.svg";
import brainIcon from "../../../assets/images/brain.svg";
import vector1 from "../../../assets/images/vector1.svg";
---

<section
  class="hero"
  style={`background-image: url(${heroImage.src});`}
>
  <div class="hero-card">
    <div class="hero-card__content">
      <h1 class="h2">
        Your Safe Space <br />
        For Mental Health
      </h1>

      <p class="body-md">
        Prioritize your mental well-being and create a life filled with peace,
        purpose, and positivity. Let us guide you on your journey to a healthier
        mind.
      </p>
    </div>

    <button class="hero-btn button-lg">
      Book Appointment
    </button>

    <img src={vector1.src} alt="" class="hero-card__vector" />
  </div>

  <div class="hero-badge hero-badge--top">
    <span class="hero-badge__icon">
      <img src={plusIcon.src} alt="" />
    </span>
    <span class="inter-tight">Mind Wellness</span>
  </div>

  <div class="hero-brain">
    <img src={brainIcon.src} alt="" />
  </div>

  <div class="hero-badge hero-badge--bottom">
    <span class="hero-badge__icon">
      <img src={plusIcon.src} alt="" />
    </span>
    <span class="inter-tight">Healthy Form</span>
  </div>

  <div class="hero-stats">
    <div class="hd2">58k+
    </div>
    <div class="body-lg">
      Millions of Happy Patients,<br/>
      One Goal: Wellness
    </div>
  </div>
</section>